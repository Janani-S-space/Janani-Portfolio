<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap');

  .contact-section {
    background: radial-gradient(circle at top left, #111, #000);
    color: #fff;
    min-height: 100vh;
    padding: 80px 20px;
    font-family: 'Poppins', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 1.2s ease-in;
  }

  .contact-box {
    max-width: 750px;
    width: 100%;
    background: rgba(18, 18, 18, 0.9);
    border: 2px solid;
    border-image: linear-gradient(45deg, #00bfff, #ff69b4, #9370db) 1;
    border-radius: 25px;
    padding: 50px 40px;
    box-shadow: 0 0 30px rgba(0,255,255,0.05);
    animation: floatUp 1.8s ease-in-out;
  }

  .contact-heading {
    font-size: 3.2rem;
    font-weight: 700;
    text-align: center;
    background: linear-gradient(90deg, #00bfff, #ff69b4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 30px;
    animation: glow 3s ease-in-out infinite alternate;
  }

  .contact-text {
    font-size: 1.25rem;
    margin-bottom: 30px;
    line-height: 1.8;
    text-align: center;
    color: #ddd;
    animation: fadeInUp 2.2s ease;
  }

  .contact-links {
    font-size: 1.15rem;
    line-height: 2.4;
    margin-top: 20px;
    color: #fff;
  }

  .contact-links p {
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.2s ease;
  }

  .contact-links p:hover {
    transform: translateX(8px);
  }

  .contact-links a {
    color: #9cf;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-links a:hover {
    color: #00ffff;
    text-shadow: 0 0 5px rgba(0,255,255,0.5);
  }

  .emoji {
    font-size: 1.4em;
    display: inline-block;
    animation: floatEmoji 2.4s ease-in-out infinite;
  }

  /* === Animations === */
  @keyframes glow {
    from { text-shadow: 0 0 8px #ff69b4; }
    to   { text-shadow: 0 0 25px #00bfff; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes floatUp {
    0%   { transform: translateY(50px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes fadeInUp {
    0%   { transform: translateY(20px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes floatEmoji {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @media (max-width: 768px) {
    .contact-heading { font-size: 2.4rem; }
    .contact-text    { font-size: 1.1rem; }
    .contact-box     { padding: 30px 25px; }
  }
</style>

<div class="contact-section">
  <div class="contact-box">
    <h1 class="contact-heading">Let's Connect ✨</h1>

    <p class="contact-text">
      Got a project? A meme? A message? <span class="emoji">💌</span><br>
      I'm always up for great conversations and creative collabs.
    </p>

    <div class="contact-links">
      <p><span class="emoji">📧</span> <strong>Email:</strong> <a href="mailto:janani.workspace@gmail.com" target="_blank">janani.workspace@gmail.com</a></p>
      <p><span class="emoji">💼</span> <strong>LinkedIn:</strong> <a href="https://linkedin.com/in/janani-s-51b77b257" target="_blank">linkedin.com/in/janani</a></p>
      <p><span class="emoji">🐱</span> <strong>Mobile Number:</strong> <a href="+91 6363830359" target="_blank">+916363830359</a></p>
    </div>
  </div>
</div>
