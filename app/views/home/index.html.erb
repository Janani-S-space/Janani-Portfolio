<div class="portfolio">
  <!-- Header Section -->
  <div class="header">
    <img src="<%= asset_path('Portfolioimg.png') %>" alt="Cartoon Girl" class="avatar">
  </div>

  <!-- Intro/About Section -->
  <div class="intro" id="about">
    <div class="id-card">
      <img src="<%= asset_path('id-card.png') %>" alt="Photo ID">
    </div>
    <div class="info" style="color: #fff;">
      <h2 style="font-size: 1.8rem; font-weight: bold;">Hi, I’m Janani 👩🏻‍💻</h2>
      <p style="margin-top: 10px; font-size: 1rem; line-height: 1.6;">
        I'm an automation engineer with a passion for scripting and building scalable test automation frameworks.  
        I specialize in validation and enjoy simplifying complex hardware-software testing challenges.
      </p>
      <p style="margin-top: 10px; font-size: 1rem; line-height: 1.6;">
        Whether it's full-stack validation or low-level regression analysis, I thrive in environments that need clean, smart, and effective tooling.
      </p>
      <p style="margin-top: 10px; font-size: 1rem; line-height: 1.6;">
        Currently building cool automation at scale, and always open to exciting new roles where I can innovate and contribute!
      </p>
    </div>
  </div>

  